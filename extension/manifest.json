{
  "manifest_version": 3,
  "name": "ScrollSense",
  "version": "2.0.0",
  "description": "AI-powered scroll awareness that redirects you back to what matters.",

  "permissions": [
    "tabs",
    "storage",
    "unlimitedStorage",
    "alarms",
    "scripting"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "http://localhost/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options.html",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
